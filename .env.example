# Copy this to .env and fill in your own values.
# n8n reads these as $env.VARNAME — see the README for how to load them.


# Supabase — where the vector index and query log live.
# Find both in your Supabase project under Settings → Data API.
# The service role key bypasses RLS, so keep it secret.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here


# The site to crawl and index.
SITE_BASE_URL=https://marblebee.com
SITEMAP_URL=https://marblebee.com/sitemap.xml


# Your n8n's public URL — Twilio calls back into this host during a call,
# so it must be HTTPS and reachable from the internet. No trailing slash.
N8N_BASE_URL=https://your-n8n-host.example.com


# Where the indexing report and escalation tickets get emailed.
NOTIFICATION_EMAIL=ops@example.com


# Live agent's number — the call handler forwards to this during business
# hours. Use E.164 format (e.g. +15551234567).
LIVE_AGENT_NUMBER=+15551234567


# Not in this file: OpenAI, Gmail, Sheets, Supabase, Redis, and Twilio
# credentials all live in n8n's Credentials panel. Set them up there once
# after importing the workflows.
